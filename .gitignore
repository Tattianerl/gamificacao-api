# ==========================================
# 📦 Dependências e Artefatos de Build
# ==========================================
node_modules/
/dist/
out/
build/

# ==========================================
# 🛠️ TypeScript
# ==========================================
# Arquivo temporário de build incremental do TS
*.tsbuildinfo

# ==========================================
# 🗄️ Prisma e Bancos de Dados
# ==========================================
# Evita enviar o cliente gerado se configurado em pasta customizada
/generated/prisma

# Arquivos de log do banco de dados (se rodar SQLite local para testes, por exemplo)
*.db
*.db-journal

# ==========================================
# 🔑 Segredos e Configurações Locais (.env)
# ==========================================
# NUNCA envie estes arquivos para o Git
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# 🪵 Logs e Diagnósticos
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# 🖥️ Arquivos de Sistema (Opcional, mas recomendado)
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/